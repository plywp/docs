                "description": "Get all connector nodes"
              },
              "response": []
            },
            {
              "name": "Create Connector",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}",
                    "type": "text"
                  },
                  {
                    "key": "X-API-Key",
                    "value": "{{api_key}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"locationId\": 1,\n  \"serverIp\": \"192.168.1.10\",\n  \"fqdn\": \"node1.example.com\",\n  \"webServer\": \"nginx\",\n  \"dataDir\": \"/srv/plywp\",\n  \"autoSsl\": true,\n  \"daemonSslEnabled\": true,\n  \"dnsServerAddress\": \"127.0.0.1\",\n  \"dnsServerPort\": 53\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/application/connectors",
                  "host": ["{{base_url}}"],
                  "path": ["api", "application", "connectors"]
                },
                "description": "Register a new server node as a connector"
              },
              "response": []
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5173",
      "description": "API base URL"
    },
    {
      "key": "api_key",
      "value": "your_api_key_here",
      "description": "Your API key for authentication"
    },
    {
      "key": "admin_token",
      "value": "your_admin_token_here",
      "description": "Admin authentication token"
    },
    {
      "key": "site_id",
      "value": "site_123",
      "description": "Site identifier"
    }
  ]
