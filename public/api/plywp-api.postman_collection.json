									{ "key": "x-api-key",     "value": "{{api_key}}" }
								],
								"url": {
									"raw": "{{base_url}}/api/application/sites",
									"host": ["{{base_url}}"],
									"path": ["api", "application", "sites"]
								}
							}
						},
						{
							"name": "Get Site",
							"request": {
								"method": "GET",
